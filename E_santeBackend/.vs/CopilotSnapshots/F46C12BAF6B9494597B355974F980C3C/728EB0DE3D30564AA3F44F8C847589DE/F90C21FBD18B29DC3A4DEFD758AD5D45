@page "/patients/{id:int}/edit"
@layout MedecinLayout
@using E_santeFrontend.Models
@inject E_santeFrontend.Services.PatientService Patients
@inject NavigationManager Navigation

<PageTitle>Modifier Patient - E-Santé</PageTitle>

@if (loading)
{
  <div class="loading-state">
    <div class="spinner"></div>
    <p>Chargement des informations du patient...</p>
  </div>
}
else if (!string.IsNullOrEmpty(error))
{
  <div class="alert-error">
    <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
    </svg>
    <span>@error</span>
  </div>
}
else if (!string.IsNullOrEmpty(success))
{
  <div class="alert-success">
    <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
    </svg>
    <span>@success</span>
  </div>
}

@if (model is not null)
{
  <div class="page-header">
    <div class="header-content">
      <h1 class="page-title">Modifier Patient</h1>
      <p class="page-subtitle">Mettre à jour les informations du patient</p>
    </div>
    <button class="btn-back" @onclick="@(() => Navigation.NavigateTo($"/patients/{id}"))">
      <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/>
      </svg>
      <span>Annuler</span>
    </button>
  </div>

  <div class="form-container">
    <div class="form-card">
      <div class="form-header-section">
        <div class="patient-avatar-large">
          <span>@GetInitials(model.Nom, model.Prenom)</span>
        </div>
        <div class="patient-info">
          <h2 class="patient-name">@model.Prenom @model.Nom</h2>
          <p class="patient-meta">Modification des informations</p>
        </div>
      </div>

      <EditForm Model="model" OnValidSubmit="Save" class="edit-form">
        <DataAnnotationsValidator />
        
        <div class="form-section">
          <h3 class="form-section-title">
            <svg class="section-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
            </svg>
            Informations Personnelles
          </h3>
          
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="nom">Nom</label>
              <InputText id="nom" @bind-Value="model.Nom" class="form-input" placeholder="Nom de famille" />
              <ValidationMessage For="@(() => model.Nom)" class="validation-message" />
            </div>

            <div class="form-group">
              <label class="form-label" for="prenom">Prénom</label>
              <InputText id="prenom" @bind-Value="model.Prenom" class="form-input" placeholder="Prénom" />
              <ValidationMessage For="@(() => model.Prenom)" class="validation-message" />
            </div>
          </div>
        </div>

        <div class="form-section">
          <h3 class="form-section-title">
            <svg class="section-icon" viewBox="0 0 20 20" fill="currentColor">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
            Coordonnées
          </h3>
          
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label" for="email">Email</label>
              <InputText id="email" @bind-Value="model.Email" class="form-input" type="email" placeholder="email@exemple.com" />
              <ValidationMessage For="@(() => model.Email)" class="validation-message" />
            </div>

            <div class="form-group">
              <label class="form-label" for="telephone">Téléphone</label>
              <InputText id="telephone" @bind-Value="model.Telephone" class="form-input" placeholder="+33 6 12 34 56 78" />
              <ValidationMessage For="@(() => model.Telephone)" class="validation-message" />
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="button" class="btn-secondary" @onclick="@(() => Navigation.NavigateTo($"/patients/{id}"))">
            <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
            </svg>
            <span>Annuler</span>
          </button>
          <button type="submit" class="btn-primary" disabled="@saving">
            @if (saving)
            {
              <div class="btn-spinner"></div>
              <span>Enregistrement...</span>
            }
            else
            {
              <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
                <path d="M7.707 10.293a1 1 0 10-1.414 1.414l3 3a1 1 0 001.414 0l3-3a1 1 0 00-1.414-1.414L11 11.586V6h5a2 2 0 012 2v7a2 2 0 01-2 2H4a2 2 0 01-2-2V8a2 2 0 012-2h5v5.586l-1.293-1.293zM9 4a1 1 0 012 0v2H9V4z"/>
              </svg>
              <span>Enregistrer les modifications</span>
            }
          </button>
        </div>
      </EditForm>
    </div>
  </div>
}

@code {
  [Parameter] public int id { get; set; }
  private PatientDto? model;
  private bool loading;
  private bool saving;
  private string? error;
  private string? success;

  protected override async Task OnParametersSetAsync()
  {
    loading = true;
    try
    {
      model = await Patients.GetPatientAsync(id);
    }
    catch (Exception ex)
    {
      error = $"Erreur lors du chargement: {ex.Message}";
    }
    finally
    {
      loading = false;
    }
  }

  private async Task Save()
  {
    if (model is null) return;
    
    saving = true;
    error = null;
    success = null;

    try
    {
      await Patients.UpdatePatientAsync(id, model);
      success = "Patient mis à jour avec succès!";
      await Task.Delay(1500);
      Navigation.NavigateTo($"/patients/{id}");
    }
    catch (Exception ex)
    {
      error = $"Erreur lors de la sauvegarde: {ex.Message}";
    }
    finally
    {
      saving = false;
    }
  }

  private string GetInitials(string nom, string prenom)
  {
    var n = !string.IsNullOrEmpty(nom) ? nom[0].ToString().ToUpper() : "";
    var p = !string.IsNullOrEmpty(prenom) ? prenom[0].ToString().ToUpper() : "";
    return $"{p}{n}";
  }
}
