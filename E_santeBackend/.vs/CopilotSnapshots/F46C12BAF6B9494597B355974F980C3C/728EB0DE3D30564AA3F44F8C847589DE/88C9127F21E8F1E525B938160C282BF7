@page "/patients"
@layout MedecinLayout
@using E_santeFrontend.Models
@inject E_santeFrontend.Services.PatientService Patients

<PageTitle>Patients - E-Santé</PageTitle>

<div class="page-header">
  <div class="header-content">
    <h1 class="page-title">Mes Patients</h1>
    <p class="page-subtitle">Liste de vos patients suivis</p>
  </div>
  <button class="btn-primary-action">
    <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
    </svg>
    <span>Nouveau Patient</span>
  </button>
</div>

@if (loading)
{
  <div class="loading-state">
    <div class="spinner"></div>
    <p>Chargement des patients...</p>
  </div>
}
else if (!string.IsNullOrEmpty(error))
{
  <div class="alert-error">
    <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
    </svg>
    <span>@error</span>
  </div>
}
else if (items?.Count > 0)
{
  <div class="patients-grid">
    @foreach (var patient in items)
    {
      <div class="patient-card">
        <div class="patient-card-header">
          <div class="patient-avatar-large">
            <span>@GetInitials(patient.Nom, patient.Prenom)</span>
          </div>
        </div>
        <div class="patient-card-body">
          <h3 class="patient-name">@patient.Prenom @patient.Nom</h3>
          <div class="patient-details">
            <div class="detail-item">
              <svg class="detail-icon" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
              <span>@patient.Email</span>
            </div>
            <div class="detail-item">
              <svg class="detail-icon" viewBox="0 0 20 20" fill="currentColor">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
              <span>@patient.Telephone</span>
            </div>
          </div>
        </div>
        <div class="patient-card-footer">
          <button class="btn-view-patient">
            <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
              <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
            </svg>
            Voir le dossier
          </button>
        </div>
      </div>
    }
  </div>
}
else
{
  <div class="content-placeholder">
    <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
      <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <h3>Aucun patient</h3>
    <p>Commencez à ajouter vos patients</p>
  </div>
}

@code {
    private List<PatientDto>? items;
    private bool loading;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            items = await Patients.GetPatientsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private string GetInitials(string nom, string prenom)
    {
        var n = !string.IsNullOrEmpty(nom) ? nom[0].ToString().ToUpper() : "";
        var p = !string.IsNullOrEmpty(prenom) ? prenom[0].ToString().ToUpper() : "";
        return $"{p}{n}";
    }
}
