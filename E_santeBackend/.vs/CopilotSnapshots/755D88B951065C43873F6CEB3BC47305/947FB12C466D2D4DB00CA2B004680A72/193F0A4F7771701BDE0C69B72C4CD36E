@page "/dashboard/patient"
@layout PatientLayout
@inject NavigationManager Nav
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService

<PageTitle>Tableau de bord</PageTitle>

<div class="patient-dashboard-content">
  @if (loading)
  {
    <div class="loading-state">
      <div class="spinner"></div>
      <p>Chargement de vos données...</p>
    </div>
  }
  else if (!string.IsNullOrEmpty(error))
  {
    <div class="alert-error">
      <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span>@error</span>
    </div>
  }
  else
  {
    <!-- Header Section -->
    <div class="page-header">
      <div class="header-content">
        <h1 class="page-title">Bonjour, Sophie ??</h1>
        <p class="page-subtitle">Bienvenue dans votre espace santé personnel</p>
      </div>
      <button class="btn-primary-action" @onclick="GoToRendezvous">
        <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
        </svg>
        <span>Prendre Rendez-vous</span>
      </button>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card stat-card-1">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">@ordonnancesCount</div>
          <div class="stat-label">Ordonnances actives</div>
        </div>
      </div>

      <div class="stat-card stat-card-2">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">@nextRdvDate</div>
          <div class="stat-label">Prochain RDV</div>
        </div>
      </div>

      <div class="stat-card stat-card-3">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">@medsInProgress</div>
          <div class="stat-label">Médicaments en cours</div>
        </div>
      </div>

      <div class="stat-card stat-card-4">
        <div class="stat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-info">
          <div class="stat-value">@notificationsCount</div>
          <div class="stat-label">Notifications</div>
        </div>
      </div>
    </div>

    <!-- Main Content Grid -->
    <div class="content-grid">
      <!-- Left Column -->
      <div class="content-column">
        <!-- Next Appointment Card -->
        <div class="card appointment-card">
          <div class="card-header">
            <h3 class="card-title">
              <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Prochain Rendez-vous
            </h3>
          </div>
          <div class="card-body">
            <div class="appointment-info">
              <div class="appointment-date">
                <div class="date-number">20</div>
                <div class="date-month">Jan</div>
              </div>
              <div class="appointment-details">
                <h4 class="doctor-name">Dr. Laurent</h4>
                <p class="specialty">Médecine générale</p>
                <div class="appointment-time">
                  <svg class="time-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                  </svg>
                  10:30
                </div>
              </div>
            </div>
            <div class="appointment-location">
              <svg class="location-icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
              15 Rue de la Santé, 75014 Paris
            </div>
            <div class="appointment-actions">
              <button class="btn-secondary" @onclick="GoToRendezvous">Modifier</button>
              <button class="btn-danger">Annuler</button>
            </div>
          </div>
        </div>

        <!-- Ordonnances Card -->
        <div class="card ordonnances-card">
          <div class="card-header">
            <h3 class="card-title">
              <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Mes Ordonnances
            </h3>
          </div>
          <div class="card-body">
            @if (recentOrdonnances?.Any() == true)
            {
              <div class="ordonnances-list">
                @foreach (var o in recentOrdonnances)
                {
                  <div class="ordonnance-item">
                    <div class="ordonnance-icon">
                      <svg viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                      </svg>
                    </div>
                    <div class="ordonnance-info">
                      <h4 class="ordonnance-title">@o.Description</h4>
                      <p class="ordonnance-meta">Dr. Laurent • 15 Jan 2024</p>
                    </div>
                    <span class="badge badge-active">Active</span>
                  </div>
                }
              </div>
            }
            else
            {
              <div class="empty-state">
                <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p>Aucune ordonnance récente</p>
              </div>
            }
            <div class="card-footer">
              <a href="/ordonnances" class="link-primary">Voir toutes mes ordonnances ?</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Column -->
      <div class="content-column">
        <!-- Doctor Card -->
        <div class="card doctor-card">
          <div class="card-header">
            <h3 class="card-title">
              <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Mon Médecin Traitant
            </h3>
          </div>
          <div class="card-body">
            <div class="doctor-profile">
              <div class="doctor-avatar">
                <span>ML</span>
              </div>
              <div class="doctor-info">
                <h4 class="doctor-name">Dr. Marie Laurent</h4>
                <p class="doctor-specialty">Médecine générale</p>
              </div>
            </div>
            <div class="doctor-contact">
              <div class="contact-item">
                <svg class="contact-icon" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
                </svg>
                01 23 45 67 89
              </div>
              <div class="contact-item">
                <svg class="contact-icon" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                15 Rue de la Santé, 75014 Paris
              </div>
            </div>
            <button class="btn-primary-full">Contacter</button>
          </div>
        </div>

        <!-- Notifications Card -->
        <div class="card notifications-card">
          <div class="card-header">
            <h3 class="card-title">
              <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Notifications
            </h3>
          </div>
          <div class="card-body">
            <div class="notifications-list">
              <div class="notification-item notification-warning">
                <div class="notification-icon">
                  <svg viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="notification-content">
                  <h4 class="notification-title">Rappel rendez-vous</h4>
                  <p class="notification-text">Vous avez un rendez-vous demain à 10h</p>
                </div>
              </div>

              <div class="notification-item notification-success">
                <div class="notification-icon">
                  <svg viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="notification-content">
                  <h4 class="notification-title">Ordonnance prête</h4>
                  <p class="notification-text">Votre ordonnance est disponible en pharmacie</p>
                </div>
              </div>

              <div class="notification-item notification-danger">
                <div class="notification-icon">
                  <svg viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="notification-content">
                  <h4 class="notification-title">Stock faible</h4>
                  <p class="notification-text">Amoxicilline 500mg en rupture de stock</p>
                </div>
              </div>
            </div>
            <div class="card-footer">
              <button class="btn-text">Marquer tout comme lu</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  }
</div>

@code {
  private bool loading;
  private string? error;
  private string ordonnancesCount = "0";
  private string notificationsCount = "3";
  private string medsInProgress = "4";
  private string nextRdvDate = "20 Jan";
  private List<E_santeFrontend.Models.OrdonnanceDto>? recentOrdonnances;

  private void GoToRendezvous() => Nav.NavigateTo("/rendezvous");

  protected override async Task OnInitializedAsync()
  {
    loading = true;
    try
    {
      var ords = await OrdonnanceService.GetOrdonnancesAsync();
      ordonnancesCount = (ords?.Count ?? 0).ToString();
      recentOrdonnances = ords?.Take(2).ToList();
    }
    catch (Exception ex)
    {
      error = ex.Message;
    }
    finally
    {
      loading = false;
    }
  }
}
