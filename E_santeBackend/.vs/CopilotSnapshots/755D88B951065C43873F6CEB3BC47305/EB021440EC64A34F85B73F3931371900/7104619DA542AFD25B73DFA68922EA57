@page "/dashboard/admin"
@layout AdminLayout
@using E_santeFrontend.Models
@inject NavigationManager Nav
@inject E_santeFrontend.Services.PatientService PatientService
@inject E_santeFrontend.Services.MedicamentService MedicamentService
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService
@inject E_santeFrontend.Services.NotificationService NotificationService
@inject E_santeFrontend.Services.AdminService AdminService

<PageTitle>Tableau de bord Admin - E-Santé</PageTitle>

<div class="dashboard-admin">
  @if (loading)
  {
    <div class="loading-state">
      <div class="spinner"></div>
      <p>Chargement du tableau de bord...</p>
    </div>
  }
  else if (!string.IsNullOrEmpty(error))
  {
    <div class="alert-error">
      <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span>@error</span>
    </div>
  }
  else
  {
    <!-- Welcome Header -->
    <div class="dashboard-header">
      <div class="welcome-section">
        <h1 class="dashboard-title">Bienvenue, <span class="gradient-text">Administrateur</span></h1>
        <p class="dashboard-subtitle">
          <svg class="subtitle-icon" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
          </svg>
          Voici un aperçu de votre système de santé
        </p>
      </div>
    </div>

    <!-- Create Forms Section -->
    <div class="create-forms-section">
      <!-- Create Medecin Form -->
      <div class="create-form-card">
        <div class="form-card-header">
          <div class="form-card-icon medecin-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="form-card-title">
            <h3>Créer un Médecin</h3>
            <p>Ajouter un nouveau médecin au système</p>
          </div>
        </div>
        
        <EditForm Model="newMedecin" OnValidSubmit="CreateMedecin" class="create-form">
          @if (!string.IsNullOrWhiteSpace(adminErrorMedecin))
          {
            <div class="form-alert-error">
              <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              <span>@adminErrorMedecin</span>
            </div>
          }
          
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Nom</label>
              <InputText class="form-input" @bind-Value="newMedecin.Nom" placeholder="Entrez le nom" />
            </div>
            <div class="form-group">
              <label class="form-label">Prénom</label>
              <InputText class="form-input" @bind-Value="newMedecin.Prenom" placeholder="Entrez le prénom" />
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <InputText class="form-input" @bind-Value="newMedecin.Email" placeholder="email@example.com" />
            </div>
            <div class="form-group">
              <label class="form-label">Spécialité</label>
              <InputText class="form-input" @bind-Value="newMedecin.Specialite" placeholder="Cardiologue, etc." />
            </div>
            <div class="form-group">
              <label class="form-label">Code Médecin</label>
              <InputText class="form-input" @bind-Value="newMedecin.CodeMedecin" placeholder="Code unique" />
            </div>
            <div class="form-group">
              <label class="form-label">Mot de passe</label>
              <InputText class="form-input" @bind-Value="newMedecin.Password" placeholder="••••••••" type="password" />
            </div>
          </div>
          
          <button type="submit" class="btn-submit btn-medecin">
            <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
            </svg>
            Créer Médecin
          </button>
        </EditForm>
      </div>

      <!-- Create Pharmacien Form -->
      <div class="create-form-card">
        <div class="form-card-header">
          <div class="form-card-icon pharmacien-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="form-card-title">
            <h3>Créer un Pharmacien</h3>
            <p>Ajouter un nouveau pharmacien au système</p>
          </div>
        </div>
        
        <EditForm Model="newPharmacien" OnValidSubmit="CreatePharmacien" class="create-form">
          @if (!string.IsNullOrWhiteSpace(adminErrorPharmacien))
          {
            <div class="form-alert-error">
              <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
              </svg>
              <span>@adminErrorPharmacien</span>
            </div>
          }
          
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Nom</label>
              <InputText class="form-input" @bind-Value="newPharmacien.Nom" placeholder="Entrez le nom" />
            </div>
            <div class="form-group">
              <label class="form-label">Prénom</label>
              <InputText class="form-input" @bind-Value="newPharmacien.Prenom" placeholder="Entrez le prénom" />
            </div>
            <div class="form-group">
              <label class="form-label">Email</label>
              <InputText class="form-input" @bind-Value="newPharmacien.Email" placeholder="email@example.com" />
            </div>
            <div class="form-group">
              <label class="form-label">Téléphone</label>
              <InputText class="form-input" @bind-Value="newPharmacien.Telephone" placeholder="+33 6 12 34 56 78" />
            </div>
            <div class="form-group">
              <label class="form-label">Licence</label>
              <InputText class="form-input" @bind-Value="newPharmacien.Licence" placeholder="Numéro de licence" />
            </div>
            <div class="form-group">
              <label class="form-label">Pharmacie ID</label>
              <InputNumber class="form-input" @bind-Value="newPharmacien.PharmacieId" placeholder="ID de la pharmacie" />
            </div>
            <div class="form-group">
              <label class="form-label">Mot de passe</label>
              <InputText class="form-input" @bind-Value="newPharmacien.Password" placeholder="••••••••" type="password" />
            </div>
          </div>
          
          <button type="submit" class="btn-submit btn-pharmacien">
            <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd"/>
            </svg>
            Créer Pharmacien
          </button>
        </EditForm>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card stat-card-primary">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Total Utilisateurs</div>
          <div class="stat-value">@totalUsers</div>
          <div class="stat-badge badge-primary">@trendUsers</div>
        </div>
      </div>

      <div class="stat-card stat-card-success">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Patients Enregistrés</div>
          <div class="stat-value">@patientsCount</div>
          <div class="stat-badge badge-success">@trendPatients</div>
        </div>
      </div>

      <div class="stat-card stat-card-info">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Médecins Actifs</div>
          <div class="stat-value">@medecinsActifs</div>
        </div>
      </div>

      <div class="stat-card stat-card-warning">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Ordonnances Actives</div>
          <div class="stat-value">@ordonnancesCount</div>
          <div class="stat-badge badge-warning">@trendOrdonnances</div>
        </div>
      </div>

      <div class="stat-card stat-card-purple">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Médicaments Stock</div>
          <div class="stat-value">@medicamentsCount</div>
        </div>
      </div>

      <div class="stat-card stat-card-danger">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Alertes Stock</div>
          <div class="stat-value">@alertsCount</div>
        </div>
      </div>
    </div>

    <!-- Charts & Tables Section -->
    <div class="dashboard-content">
      <!-- Chart Section -->
      <div class="content-card chart-card">
        <div class="card-header">
          <div class="card-title-section">
            <h3 class="card-title">Nouvelles Inscriptions</h3>
            <p class="card-subtitle">Évolution des inscriptions</p>
          </div>
          <div class="date-range">
            <svg class="date-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <span>Oct - Jan</span>
          </div>
        </div>
        <div class="chart-container">
          <Components.StatChart Title="Inscriptions" Subtitle="Oct - Jan" Data="@activityData" />
        </div>
      </div>

      <!-- Recent Patients Table -->
      <div class="content-card table-card">
        <div class="card-header">
          <div class="card-title-section">
            <h3 class="card-title">Derniers Patients Inscrits</h3>
            <p class="card-subtitle">Nouveaux patients dans le système</p>
          </div>
        </div>
        <div class="table-container">
          <table class="data-table">
            <thead>
              <tr>
                <th>Patient</th>
                <th>Téléphone</th>
                <th>Email</th>
              </tr>
            </thead>
            <tbody>
              @if (recentPatients?.Any() == true)
              {
                @foreach (var p in recentPatients)
                {
                  <tr>
                    <td>
                      <div class="patient-cell">
                        <div class="patient-avatar">
                          <span>@GetInitials(p.Nom, p.Prenom)</span>
                        </div>
                        <div class="patient-info">
                          <div class="patient-name">@p.Prenom @p.Nom</div>
                        </div>
                      </div>
                    </td>
                    <td class="phone-cell">@p.Telephone</td>
                    <td class="email-cell">@p.Email</td>
                  </tr>
                }
              }
              else
              {
                <tr>
                  <td colspan="3" class="no-data">Aucun patient récent</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Medications Stock Table -->
    <div class="medications-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <h2 class="section-title">État des Stocks Médicaments</h2>
          <span class="section-badge">@medicamentsCount médicaments</span>
        </div>
      </div>

      <div class="table-container">
        <table class="medications-table">
          <thead>
            <tr>
              <th>Médicament</th>
              <th>Catégorie</th>
              <th>Stock</th>
              <th>Statut</th>
            </tr>
          </thead>
          <tbody>
            @if (medsTable?.Any() == true)
            {
              @foreach (var m in medsTable)
              {
                var status = m.stock < 20 ? "Stock faible" : "OK";
                <tr class="table-row">
                  <td>
                    <div class="med-cell">
                      <div class="med-icon">
                        <svg viewBox="0 0 20 20" fill="currentColor">
                          <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
                        </svg>
                      </div>
                      <span class="med-name">@m.name</span>
                    </div>
                  </td>
                  <td class="category-cell">@m.category</td>
                  <td class="stock-cell">
                    <span class="stock-badge @(m.stock < 20 ? "stock-low" : "stock-ok")">@m.stock unités</span>
                  </td>
                  <td>
                    @if (status == "Stock faible")
                    {
                      <span class="status-badge status-warning">@status</span>
                    }
                    else
                    {
                      <span class="status-badge status-success">@status</span>
                    }
                  </td>
                </tr>
              }
            }
            else
            {
              <tr>
                <td colspan="4" class="no-data">Aucun médicament disponible</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  }
</div>

@code {
    private string totalUsers = "0";
    private string patientsCount = "0";
    private string medicamentsCount = "0";
    private string ordonnancesCount = "0";
    private string medecinsActifs = "0";
    private string alertsCount = "0";
    private string trendUsers = string.Empty;
    private string trendPatients = string.Empty;
    private string trendOrdonnances = string.Empty;
    private bool loading;
    private string? error;
    private int[] activityData = new[] { 200, 400, 600, 800 };
    private List<E_santeFrontend.Models.PatientDto>? recentPatients;
    private List<(string name, string category, int stock)>? medsTable;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var patients = await PatientService.GetPatientsAsync();
            var meds = await MedicamentService.GetMedicamentsAsync();
            var ords = await OrdonnanceService.GetOrdonnancesAsync();
            var notes = await NotificationService.GetNotificationsAsync();
            var medecins = await AdminService.GetMedecinsAsync();

            patientsCount = (patients?.Count ?? 0).ToString();
            medicamentsCount = (meds?.Count ?? 0).ToString();
            ordonnancesCount = (ords?.Count ?? 0).ToString();
            alertsCount = (notes?.Count ?? 0).ToString();
            medecinsActifs = (medecins?.Count ?? 0).ToString();
            totalUsers = CalcTotalUsers(patients?.Count ?? 0, medecins?.Count ?? 0);

            recentPatients = patients?.Take(5).ToList();
            medsTable = meds?.Take(6).Select(x => (x.Nom ?? "—", x.Code ?? "—", 0)).ToList();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private AdminCreateMedecinDto newMedecin = new();
    private AdminCreatePharmacienDto newPharmacien = new();
    private string? adminErrorMedecin;
    private string? adminErrorPharmacien;

    private string CalcTotalUsers(int patients, int medecins)
        => (patients + medecins).ToString();

    private async Task CreateMedecin()
    {
        try
        {
            var ok = await AdminService.CreateMedecinAsync(newMedecin);
            if (ok)
            {
                var patients = await PatientService.GetPatientsAsync();
                var medecins = await AdminService.GetMedecinsAsync();
                patientsCount = (patients?.Count ?? 0).ToString();
                medecinsActifs = (medecins?.Count ?? 0).ToString();
                totalUsers = CalcTotalUsers(patients?.Count ?? 0, medecins?.Count ?? 0);
                adminErrorMedecin = null;
                newMedecin = new();
            }
            else
            {
                adminErrorMedecin = AdminService.LastError;
            }
        }
        catch { }
    }

    private async Task CreatePharmacien()
    {
        try
        {
            var ok = await AdminService.CreatePharmacienAsync(newPharmacien);
            if (ok)
            {
                var patients = await PatientService.GetPatientsAsync();
                var medecins = await AdminService.GetMedecinsAsync();
                patientsCount = (patients?.Count ?? 0).ToString();
                medecinsActifs = (medecins?.Count ?? 0).ToString();
                totalUsers = CalcTotalUsers(patients?.Count ?? 0, medecins?.Count ?? 0);
                adminErrorPharmacien = null;
                newPharmacien = new();
            }
            else
            {
                adminErrorPharmacien = AdminService.LastError;
            }
        }
        catch { }
    }

    private string GetInitials(string nom, string prenom)
    {
        var n = !string.IsNullOrEmpty(nom) ? nom[0].ToString().ToUpper() : "";
        var p = !string.IsNullOrEmpty(prenom) ? prenom[0].ToString().ToUpper() : "";
        return $"{p}{n}";
    }
}
