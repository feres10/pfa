@page "/dashboard/pharmacien"
@layout PharmacienLayout
@inject NavigationManager Nav
@inject E_santeFrontend.Services.StockService StockService
@inject E_santeFrontend.Services.MedicamentService MedicamentService
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService
@inject E_santeFrontend.Services.PatientService PatientService
@inject E_santeFrontend.Services.AdminService AdminService

<PageTitle>Tableau de bord Pharmacien - E-Santé</PageTitle>

<div class="dashboard-pharmacien">
  @if (loading)
  {
    <div class="loading-state">
      <div class="spinner"></div>
      <p>Chargement du tableau de bord...</p>
    </div>
  }
  else if (!string.IsNullOrEmpty(error))
  {
    <div class="alert-error">
      <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
      </svg>
      <span>@error</span>
    </div>
  }
  else
  {
    <!-- Welcome Header -->
    <div class="dashboard-header">
      <div class="welcome-section">
        <h1 class="dashboard-title">Bienvenue, <span class="gradient-text">@pharmacieName</span></h1>
        <p class="dashboard-subtitle">
          <svg class="subtitle-icon" viewBox="0 0 20 20" fill="currentColor">
            <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
          </svg>
          @ordonnancesEnAttente ordonnances en attente de traitement
        </p>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="stats-grid">
      <div class="stat-card stat-card-primary">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Ordonnances à Traiter</div>
          <div class="stat-value">@ordonnancesEnAttente</div>
        </div>
      </div>

      <div class="stat-card stat-card-success">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Dispensations Jour</div>
          <div class="stat-value">@dispensationsJour</div>
          <div class="stat-badge badge-success">@dispPercent</div>
        </div>
      </div>

      <div class="stat-card stat-card-warning">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Stock Critique</div>
          <div class="stat-value">@stockCritique</div>
        </div>
      </div>

      <div class="stat-card stat-card-info">
        <div class="stat-icon-wrapper">
          <svg class="stat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="stat-content">
          <div class="stat-label">Ventes du Jour</div>
          <div class="stat-value">@ventesJour</div>
          <div class="stat-badge badge-info">@salesPercent</div>
        </div>
      </div>
    </div>

    <!-- Charts & Alerts Section -->
    <div class="dashboard-content">
      <!-- Dispensations Chart -->
      <div class="content-card chart-card">
        <div class="card-header">
          <div class="card-title-section">
            <h3 class="card-title">Dispensations par Jour</h3>
            <p class="card-subtitle">Aperçu de la semaine</p>
          </div>
          <div class="date-range">
            <svg class="date-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
            </svg>
            <span>Lun - Sam</span>
          </div>
        </div>
        <div class="chart-container">
          <!-- Integrate chart library later; for now use sparkline -->
          @((MarkupString)RenderSparkline(activityOrdonnances, "#60A5FA"))
        </div>
      </div>

      <!-- Critical Stock Alerts -->
      <div class="content-card alert-card">
        <div class="card-header">
          <div class="card-title-section">
            <h3 class="card-title card-title-warning">
              <svg class="title-icon" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
              </svg>
              Stock Critique
            </h3>
            <p class="card-subtitle">Produits nécessitant une attention</p>
          </div>
        </div>
        <div class="alert-list">
          @if (lowStock?.Count > 0)
          {
            foreach (var m in lowStock)
            {
              <div class="alert-item">
                <div class="alert-item-icon">
                  <svg viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div class="alert-item-content">
                  <div class="alert-item-name">@m.Nom</div>
                  <div class="alert-item-category">Stock: @m.Stock • Expire: @m.DateExpiration?.ToString("yyyy-MM-dd")</div>
                </div>
              </div>
            }
          }
          else
          {
            <div class="no-alerts">Aucun produit en stock critique</div>
          }
        </div>
      </div>
    </div>

    <!-- Prescriptions Table -->
    <div class="prescriptions-section">
      <div class="section-header">
        <div class="section-title-wrapper">
          <h2 class="section-title">Ordonnances à Traiter</h2>
          <span class="section-badge">@ordonnancesEnAttente en attente</span>
        </div>
        <button class="btn-view-all" @onclick="GoToOrdonnances">
          <span>Voir toutes</span>
          <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>

      <div class="table-container">
        <table class="prescriptions-table">
          <thead>
            <tr>
              <th>Patient</th>
              <th>Médecin</th>
              <th>Date</th>
              <th>Nb. Médicaments</th>
              <th>Statut</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            @if (ordonnancesTable?.Count > 0)
            {
              @foreach (var ord in ordonnancesTable)
              {
                <tr class="table-row">
                  <td>
                    <div class="patient-cell">
                      <div class="patient-avatar">
                        <span>@GetInitials(ord.PatientName)</span>
                      </div>
                      <span class="patient-name">@ord.PatientName</span>
                    </div>
                  </td>
                  <td class="medecin-cell">@ord.MedecinName</td>
                  <td class="date-cell">@ord.Date.ToString("yyyy-MM-dd")</td>
                  <td class="meds-cell">
                    <span class="meds-badge">@ord.MedsCount</span>
                  </td>
                  <td>
                    <span class="status-badge status-@GetStatusClass(ord.Statut)">@ord.Statut</span>
                  </td>
                  <td>
                    <button class="btn-action" @onclick="() => ViewOrdonnance(ord.Id)">
                      <svg class="action-icon" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
                      </svg>
                      Traiter
                    </button>
                  </td>
                </tr>
              }
            }
            else
            {
              <tr><td colspan="6">Aucune ordonnance à traiter</td></tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  }
</div>

@code {
  private bool loading;
  private string? error;

  private string pharmacieName = "Pharmacie Centrale";
  private int ordonnancesEnAttente = 0;
  private int dispensationsJour = 0;
  private int stockCritique = 0;
  private string ventesJour = "0 €";
  private string dispPercent = "+0%";
  private string salesPercent = "+0%";

  private List<(int Id, string PatientName, string MedecinName, DateTime Date, int MedsCount, string Statut)>? ordonnancesTable;

  private List<E_santeFrontend.Models.MedicamentDto>? lowStock;

  private int[] activityOrdonnances = new int[7];

  protected override async Task OnInitializedAsync()
  {
    await LoadAsync();
  }

  private async Task LoadAsync()
  {
    loading = true; error = null;
    try
    {
      var ords = await OrdonnanceService.GetOrdonnancesAsync();
      var meds = await MedicamentService.GetMedicamentsAsync();
      var patients = await PatientService.GetPatientsAsync();
      var medecins = await AdminService.GetMedecinsAsync();

      ordonnancesEnAttente = ords.Count(o => string.IsNullOrWhiteSpace(o.Statut) || o.Statut.Equals("EnAttente", StringComparison.OrdinalIgnoreCase));
      dispensationsJour = ords.Count(o => DateTime.TryParse(o.Date, out var d) && d.Date == DateTime.UtcNow.Date);
      stockCritique = meds.Count(m => m.Stock <= 10);

      // ventesJour: sum of meds dispensed today -> not available in DTOs; approximate by count*price if price present; else show 0
      ventesJour = "0 €";

      activityOrdonnances = BuildDailySeriesFromOrdonnances(ords);

      ordonnancesTable = ords.OrderByDescending(o => DateTime.TryParse(o.Date, out var d) ? d : DateTime.MinValue)
        .Take(10)
        .Select(o => (
          o.Id,
          PatientName: patients.FirstOrDefault(p => p.Id == o.PatientId)?.Prenom + " " + patients.FirstOrDefault(p => p.Id == o.PatientId)?.Nom ?? "Patient inconnu",
          MedecinName: medecins?.FirstOrDefault(m => m.CodeMedecin != null && m.CodeMedecin.Equals(o.MedecinId.ToString()))?.Nom ?? "Médecin inconnu",
          Date: DateTime.TryParse(o.Date, out var dd) ? dd : DateTime.UtcNow,
          MedsCount: 0,
          Statut: o.Statut ?? "EnAttente"
        )).ToList();

      // low stock
      var soon = DateTime.UtcNow.AddDays(30);
      lowStock = meds?.Where(m => m.Stock <= 10 || (m.DateExpiration.HasValue && m.DateExpiration.Value <= soon)).ToList();
    }
    catch (Exception ex)
    {
      error = ex.Message;
    }
    finally
    {
      loading = false;
    }
  }

  private int[] BuildDailySeriesFromOrdonnances(List<E_santeFrontend.Models.OrdonnanceDto>? ords)
  {
    var series = new int[7];
    if (ords == null) return series;
    var now = DateTime.UtcNow.Date;
    for (int i = 0; i < 7; i++)
    {
      var day = now.AddDays(-6 + i);
      series[i] = ords.Count(o => DateTime.TryParse(o.Date, out var d) && d.Date == day);
    }
    return series;
  }

  private void GoToOrdonnances() => Nav.NavigateTo("/admin/ordonnances");

  private void ViewOrdonnance(int id) => Nav.NavigateTo($"/ordonnances/{id}");

  private string GetInitials(string name)
  {
    var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length >= 2) return ($"{parts[0][0]}{parts[1][0]}").ToUpper();
    return name.Length > 0 ? name[0].ToString().ToUpper() : "?";
  }

  private string GetStatusClass(string statut)
  {
    return statut?.ToLower() switch
    {
      "active" => "active",
      "traitee" => "completed",
      "enattente" => "pending",
      "en attente" => "pending",
      _ => "default"
    };
  }
}
