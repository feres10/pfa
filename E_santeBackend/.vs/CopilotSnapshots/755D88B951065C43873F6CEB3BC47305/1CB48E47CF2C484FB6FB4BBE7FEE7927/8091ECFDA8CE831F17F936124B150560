using System.Net.Http.Json;
using E_santeFrontend.Models;

namespace E_santeFrontend.Services
{
    public class AdminService
    {
        private readonly HttpClient _http;
        private readonly E_santeFrontend.Helpers.LocalStorageService _storage;
        public string? LastError { get; private set; }

        public AdminService(HttpClient http, E_santeFrontend.Helpers.LocalStorageService storage)
        {
            _http = http;
            _storage = storage;
        }

        private async Task EnsureAuthHeaderAsync()
        {
            try
            {
                var token = await _storage.GetItemAsync("auth_token");
                if (!string.IsNullOrWhiteSpace(token))
                {
                    _http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                }
            }
            catch { }
        }

        public class MedecinListItem
        {
            public int Id { get; set; }
            public string? Nom { get; set; }
            public string? Prenom { get; set; }
            public string? Specialite { get; set; }
            public string? CodeMedecin { get; set; }
            // Email may not be present in backend DTO; keep for UI compatibility
            public string? Email { get; set; }
        }

        public async Task<List<MedecinListItem>?> GetMedecinsAsync()
        {
            await EnsureAuthHeaderAsync();
            try
            {
                // Backend controller is MedecinController with route api/Medecin
                var list = await _http.GetFromJsonAsync<List<MedecinListItem>>("api/Medecin", new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                return list ?? new List<MedecinListItem>();
            }
            catch (Exception ex)
            {
                LastError = ex.Message;
                return new List<MedecinListItem>();
            }
        }

        public async Task<List<AdminCreatePharmacienDto>?> GetPharmaciensAsync()
        {
            await EnsureAuthHeaderAsync();
            try
            {
                return await _http.GetFromJsonAsync<List<AdminCreatePharmacienDto>>("api/admin/pharmaciens", new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            catch { return new List<AdminCreatePharmacienDto>(); }
        }

        public async Task<int> GetMedecinsCountAsync()
        {
            var list = await GetMedecinsAsync();
            return list?.Count ?? 0;
        }

        public async Task<bool> CreateMedecinAsync(AdminCreateMedecinDto dto)
        {
            await EnsureAuthHeaderAsync();
            LastError = null;
            // Basic client-side validation to avoid common 400s
            if (string.IsNullOrWhiteSpace(dto.Nom) || string.IsNullOrWhiteSpace(dto.Prenom))
            {
                LastError = "Nom et Prénom sont requis";
                return false;
            }
            if (string.IsNullOrWhiteSpace(dto.Email))
            {
                LastError = "Email est requis";
                return false;
            }
            if (string.IsNullOrWhiteSpace(dto.Password))
            {
                LastError = "Mot de passe est requis";
                return false;
            }
            var resp = await _http.PostAsJsonAsync(
                "api/admin/medecins",
                dto,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }
            );
            if (!resp.IsSuccessStatusCode)
            {
                try
                {
                    var json = await resp.Content.ReadAsStringAsync();
                    using var doc = System.Text.Json.JsonDocument.Parse(json);
                    if (doc.RootElement.TryGetProperty("message", out var m))
                        LastError = m.GetString();
                    else if (doc.RootElement.TryGetProperty("errors", out var errs) && errs.ValueKind == System.Text.Json.JsonValueKind.Object)
                    {
                        // Aggregate model validation errors if present
                        var msgs = new System.Collections.Generic.List<string>();
                        foreach (var prop in errs.EnumerateObject())
                        {
                            foreach (var item in prop.Value.EnumerateArray())
                            {
                                msgs.Add(item.GetString() ?? string.Empty);
                            }
                        }
                        LastError = string.Join("; ", msgs);
                    }
                    else
                        LastError = json;
                }
                catch
                {
                    LastError = resp.ReasonPhrase;
                }
                return false;
            }
            return true;
        }

        public async Task<bool> CreatePharmacienAsync(AdminCreatePharmacienDto dto)
        {
            await EnsureAuthHeaderAsync();
            LastError = null;
            // Basic client-side validation to avoid common 400s
            if (string.IsNullOrWhiteSpace(dto.Nom) || string.IsNullOrWhiteSpace(dto.Prenom))
            {
                LastError = "Nom et Prénom sont requis";
                return false;
            }
            if (string.IsNullOrWhiteSpace(dto.Email))
            {
                LastError = "Email est requis";
                return false;
            }
            if (string.IsNullOrWhiteSpace(dto.Password))
            {
                LastError = "Mot de passe est requis";
                return false;
            }
            if (dto.PharmacieId <= 0)
            {
                LastError = "PharmacieId doit être supérieur à 0";
                return false;
            }
            var resp = await _http.PostAsJsonAsync(
                "api/admin/pharmaciens",
                dto,
                new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = null }
            );
            if (!resp.IsSuccessStatusCode)
            {
                try
                {
                    var json = await resp.Content.ReadAsStringAsync();
                    using var doc = System.Text.Json.JsonDocument.Parse(json);
                    if (doc.RootElement.TryGetProperty("message", out var m))
                        LastError = m.GetString();
                    else if (doc.RootElement.TryGetProperty("errors", out var errs) && errs.ValueKind == System.Text.Json.JsonValueKind.Object)
                    {
                        var msgs = new System.Collections.Generic.List<string>();
                        foreach (var prop in errs.EnumerateObject())
                        {
                            foreach (var item in prop.Value.EnumerateArray())
                            {
                                msgs.Add(item.GetString() ?? string.Empty);
                            }
                        }
                        LastError = string.Join("; ", msgs);
                    }
                    else
                        LastError = json;
                }
                catch
                {
                    LastError = resp.ReasonPhrase;
                }
                return false;
            }
            return true;
        }
    }
}
