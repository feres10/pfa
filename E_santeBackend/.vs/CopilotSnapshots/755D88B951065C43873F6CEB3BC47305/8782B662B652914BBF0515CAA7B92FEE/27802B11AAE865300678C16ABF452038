@page "/rendezvous/new"
@layout PatientLayout
@inject E_santeFrontend.Services.RendezvousService RendezvousService
@inject NavigationManager Nav

<PageTitle>Nouveau rendez-vous</PageTitle>

<div class="page">
  <h1>Prendre rendez-vous</h1>
  <p class="muted">Choisissez une date et une heure</p>

  @if (!string.IsNullOrEmpty(error))
  {
    <div class="alert-error">@error</div>
  }

  <div class="form-row">
    <label>Date</label>
    <input type="date" @bind="date" />
  </div>
  <div class="form-row">
    <label>Heure</label>
    <input type="time" @bind="heure" />
  </div>
  <div class="form-row">
    <label>Médecin Id</label>
    <input type="number" @bind="medecinId" />
  </div>
  <div class="form-row">
    <label>Lieu</label>
    <input type="text" @bind="lieu" />
  </div>

  <div class="form-actions">
    <button class="btn-primary" @onclick="Create">Prendre</button>
    <button class="btn-outline" @onclick="() => Nav.NavigateTo('/rendezvous')">Annuler</button>
  </div>
</div>

@code{
  private string? date;
  private string? heure;
  private int medecinId;
  private string? lieu;
  private string? error;

  private async Task Create()
  {
    error = null;
    try
    {
      var dto = new E_santeFrontend.Pages.Rendezvous.NewRendezvousDto { Date = date, Heure = heure, MedecinId = medecinId, Lieu = lieu, PatientId = 0 };
      var created = await RendezvousService.CreateAsync(dto);
      if (created != null)
      {
        Nav.NavigateTo($"/rendezvous/{created.Id}");
      }
      else
      {
        error = "Impossible de créer le rendez-vous";
      }
    }
    catch (Exception ex) { error = ex.Message; }
  }

  public class NewRendezvousDto
  {
    public int PatientId { get; set; }
    public int MedecinId { get; set; }
    public string? Date { get; set; }
    public string? Heure { get; set; }
    public string? Lieu { get; set; }
  }
}
