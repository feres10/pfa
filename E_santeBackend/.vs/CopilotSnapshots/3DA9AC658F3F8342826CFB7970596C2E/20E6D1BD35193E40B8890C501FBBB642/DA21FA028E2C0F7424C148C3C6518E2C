@page "/login"
@inject E_santeFrontend.Services.AuthService Auth
@inject NavigationManager Nav
@inject E_santeFrontend.Services.AuthService Auth
@inject E_santeFrontend.Services.PatientService PatientService

<PageTitle>Connexion</PageTitle>

<div class="container py-4">
  <a class="text-muted d-inline-flex align-items-center mb-3" href="/home">? Retour � l'accueil</a>

  <div class="d-flex flex-column align-items-center">
    <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center" style="width:56px;height:56px;">
      <span class="fw-bold">?</span>
    </div>
    <h2 class="mt-3 mb-1">E?Sant�</h2>
    <p class="text-muted mb-4">Connectez-vous � votre espace</p>

    <div class="card shadow-sm" style="max-width:520px;width:100%;">
      <div class="card-body">
        @if (!string.IsNullOrEmpty(error))
        {
          <div class="alert alert-danger">@error</div>
        }
        <EditForm Model="model" OnValidSubmit="HandleLogin">
          <div class="mb-3">
            <label class="form-label">Email</label>
            <InputText class="form-control" @bind-Value="model.Email" />
          </div>
          <div class="mb-3">
            <div class="d-flex justify-content-between">
              <label class="form-label">Mot de passe</label>
              <a href="/forgot-password" class="small text-muted">Mot de passe oubli� ?</a>
            </div>
            <InputText class="form-control" @bind-Value="model.Password" type="password" />
          </div>
          <button class="btn btn-primary w-100" type="submit" disabled="@loading">
            @(loading ? "Connexion..." : "Se connecter")
          </button>
        </EditForm>
        <div class="text-center mt-3">
          <span class="text-muted">Pas encore de compte ?</span>
          <a href="/register" class="ms-1">Cr�er un compte</a>
        </div>
      </div>
    </div>
  </div>
</div>

@code {
  private E_santeFrontend.Models.LoginDto model = new();
  private string? error;
  private bool loading;

  private async Task HandleLogin()
  {
    error = null;
    loading = true;
    var ok = await Auth.LoginAsync(model);
    loading = false;
    if (ok)
    {
      // Ensure token header applied to HttpClient before navigating
      try { await Auth.ApplyTokenToHttpClientAsync(); } catch { }

      // Quick test: call a protected endpoint to confirm token works
      try
      {
        var _ = await PatientService.GetPatientsAsync();
      }
      catch
      {
        error = "Accès refusé (401) : le token ne semble pas être transmis.";
        return;
      }

      // Redirect based on role extracted from token
      var role = Auth.CurrentRole;
      if (string.IsNullOrWhiteSpace(role))
      {
        // fallback to patient
        Nav.NavigateTo("/dashboard/patient");
      }
      else if (role.Equals("Admin", StringComparison.OrdinalIgnoreCase))
      {
        Nav.NavigateTo("/dashboard/admin");
      }
      else if (role.Equals("Medecin", StringComparison.OrdinalIgnoreCase))
      {
        Nav.NavigateTo("/dashboard/medecin");
      }
      else if (role.Equals("Pharmacien", StringComparison.OrdinalIgnoreCase))
      {
        Nav.NavigateTo("/dashboard/pharmacien");
      }
      else
      {
        Nav.NavigateTo("/dashboard/patient");
      }
    }
    else
    {
      error = Auth.LastError ?? "�chec de connexion. V�rifiez vos identifiants.";
    }
  }
}
