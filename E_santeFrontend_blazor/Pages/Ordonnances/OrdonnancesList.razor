@page "/ordonnances"
@layout MedecinLayout
@using E_santeFrontend.Models
@inject E_santeFrontend.Services.OrdonnanceService Ordonnances
@inject NavigationManager Navigation
@inject E_santeFrontend.Services.PatientService PatientService

<PageTitle>Ordonnances - E-Sant�</PageTitle>

<div class="page-header">
  <div class="header-content">
    <h1 class="page-title">Mes Ordonnances</h1>
    <p class="page-subtitle">@(filterMedecinId.HasValue ? "Ordonnances pour le médecin" : "Consultez votre historique d'ordonnances")</p>
  </div>
</div>

@if (loading)
{
  <div class="loading-state">
    <div class="spinner"></div>
    <p>Chargement de vos ordonnances...</p>
  </div>
}
else if (!string.IsNullOrEmpty(error))
{
  <div class="alert-error">
    <svg class="alert-icon" viewBox="0 0 20 20" fill="currentColor">
      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
    </svg>
    <span>@error</span>
  </div>
}
else if (items?.Count > 0)
{
  <div class="ordonnances-grid">
    @foreach (var o in items)
    {
      <div class="ordonnance-card">
        <div class="ordonnance-card-header">
          <div class="ordonnance-icon">
            <svg viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <span class="badge badge-active">Active</span>
        </div>
        <div class="ordonnance-card-body">
          <h3 class="ordonnance-title">@o.Description</h3>
          <div class="ordonnance-meta">
              <div class="meta-item">
                <svg class="meta-icon" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                </svg>
                <span>@GetPatientName(o.PatientId)</span>
              </div>
              <div class="meta-item">
                <svg class="meta-icon" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd"/>
                </svg>
                <span>@FormatDate(o.Date)</span>
              </div>
            </div>
        </div>
        <div class="ordonnance-card-footer">
          <button class="btn-delete" @onclick="() => DeleteOrdonnance(o.Id)">
            <svg class="btn-icon" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M6 7a1 1 0 011-1h6a1 1 0 011 1v8a2 2 0 01-2 2H8a2 2 0 01-2-2V7zm2-3a1 1 0 00-1 1v1h8V5a1 1 0 00-1-1H8zM5 6h10" clip-rule="evenodd"/>
            </svg>
            Supprimer
          </button>
        </div>
      </div>
    }
  </div>
}
else
{
  <div class="content-placeholder">
    <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
      <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <h3>Aucune ordonnance</h3>
    <p>Vous n'avez pas encore d'ordonnances enregistr�es</p>
  </div>
}

@code {
    private List<OrdonnanceDto>? items;
    private bool loading;
    private string? error;
    private int? filterMedecinId;
    private List<PatientDto>? patients;

    private async Task DeleteOrdonnance(int id)
    {
      try
      {
        var ok = await Ordonnances.DeleteAsync(id);
        if (ok)
        {
          items = items?.Where(x => x.Id != id).ToList();
          StateHasChanged();
        }
        else
        {
          error = "Impossible de supprimer l'ordonnance.";
        }
      }
      catch (Exception ex)
      {
        error = ex.Message;
      }
    }

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
          items = await Ordonnances.GetOrdonnancesAsync();
          patients = await PatientService.GetPatientsAsync();

          // Read optional medecinId query parameter to filter the list
          var uri = new Uri(Navigation.Uri);
          var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
          if (int.TryParse(q.Get("medecinId"), out var mid))
          {
            filterMedecinId = mid;
            items = items?.Where(o => o.MedecinId == mid).ToList();
          }
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private string GetPatientName(int id)
    {
      var p = patients?.FirstOrDefault(x => x.Id == id);
      if (p == null) return "Patient inconnu";
      return $"{(string.IsNullOrWhiteSpace(p.Prenom) ? "" : p.Prenom + " ")}{p.Nom}".Trim();
    }

    private string FormatDate(string? date)
    {
      if (string.IsNullOrWhiteSpace(date)) return "-";
      if (DateTime.TryParse(date, out var dt)) return dt.ToString("dd MMM yyyy");
      return date;
    }
}
