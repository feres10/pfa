@page "/pharmacien/ordonnances"
@layout PharmacienLayout
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService
@inject E_santeFrontend.Services.PatientService PatientService
@inject E_santeFrontend.Services.StockService StockService
@inject NavigationManager Nav

<PageTitle>Ordonnances - Pharmacien</PageTitle>

<div class="page">
  <div class="page-header">
    <h1>Ordonnances</h1>
    <p class="muted">Liste des ordonnances (vue pharmacien)</p>
  </div>

  @if (loading)
  {
    <div class="loading">Chargement...</div>
  }
  else if (!string.IsNullOrEmpty(error))
  {
    <div class="alert-error">@error</div>
  }
  else
  {
    <div class="ordonnances-grid">
      @foreach(var o in ords ?? new List<E_santeFrontend.Models.OrdonnanceDto>())
      {
        <div class="ordonnance-card">
          <div class="card-top">
            <div class="card-title">@GetPatientName(o.PatientId)</div>
            <div class="card-badge">@FormatDate(o.Date)</div>
          </div>
          <div class="card-body">
            <div class="meta"><strong>Statut:</strong> <span class="stat">@o.Statut</span></div>
          </div>
          <div class="card-actions">
            <button class="btn btn-outline" @onclick="() => ViewOrdonnance(o.Id)">Voir</button>
            @if (o.Statut == "EnAttente")
            {
              <button class="btn btn-primary" @onclick="() => TraiterOrdonnance(o.Id)">Traiter</button>
            }
          </div>
        </div>
      }
    </div>
  }
</div>

@code{
  private bool loading;
  private string? error;
  private List<E_santeFrontend.Models.OrdonnanceDto>? ords;
  private List<E_santeFrontend.Models.PatientDto>? patients;

  private bool processing;

  protected override async Task OnInitializedAsync()
  {
    loading = true;
    try
    {
      ords = await OrdonnanceService.GetOrdonnancesAsync();
      patients = await PatientService.GetPatientsAsync();
    }
    catch(Exception ex){ error = ex.Message; }
    finally{ loading = false; }
  }

  private void ViewOrdonnance(int id) => Nav.NavigateTo($"/pharmacien/ordonnances/{id}");

  private string GetPatientName(int id)
  {
    var p = patients?.FirstOrDefault(x => x.Id == id);
    if (p == null) return "Patient inconnu";
    return $"{(string.IsNullOrWhiteSpace(p.Prenom) ? "" : p.Prenom + " ")}{p.Nom}".Trim();
  }

  private string FormatDate(string? date)
  {
    if (string.IsNullOrWhiteSpace(date)) return "-";
    if (DateTime.TryParse(date, out var dt)) return dt.ToString("dd MMM yyyy");
    return date;
  }

  private async Task TraiterOrdonnance(int id)
  {
    if (processing) return;
    processing = true;
    try
    {
      var o = await OrdonnanceService.GetOrdonnanceAsync(id);
      if (o == null) { error = "Ordonnance introuvable"; return; }

      bool allOk = true;
      if (o.Lignes != null)
      {
        foreach (var l in o.Lignes)
        {
          var dto = new { Type = "Sortie", Quantite = l.Quantite, MedicamentId = l.MedicamentId };
          var ok = await StockService.AjouterMouvementAsync(dto);
          if (!ok) { allOk = false; break; }
        }
      }

      if (allOk)
      {
        var done = await OrdonnanceService.UpdateStatutAsync(id, "Traitee");
        if (done)
        {
          var it = ords?.FirstOrDefault(x => x.Id == id);
          if (it != null) it.Statut = "Traitee";
        }
        else error = "Impossible de mettre à jour le statut";
      }
      else
      {
        error = "Échec lors du traitement du stock (quantité insuffisante).";
      }
    }
    catch (Exception ex) { error = ex.Message; }
    finally { processing = false; }
  }
}
