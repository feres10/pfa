@page "/medecin/ordonnances"
@layout MedecinLayout
@inject E_santeFrontend.Services.PatientService PatientService
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService
@inject NavigationManager Nav

<PageTitle>Ordonnances - Médecin</PageTitle>

<div class="page">
  <div class="page-header">
    <div class="header-content">
      <h1 class="page-title">Ordonnances</h1>
      <p class="page-subtitle">Créer une ordonnance pour un patient</p>
    </div>
  </div>

  @if (loading)
  {
    <div class="loading-state">Chargement...</div>
  }
  else if (!string.IsNullOrEmpty(error))
  {
    <div class="alert-error">@error</div>
  }
  else
  {
    <div class="patients-table">
      <table class="modern-table">
        <thead>
          <tr><th>Patient</th><th>Email</th><th>T�l�phone</th><th></th></tr>
        </thead>
        <tbody>
          @foreach (var p in patients)
          {
            <tr>
              <td>@p.Prenom @p.Nom</td>
              <td>@p.Email</td>
              <td>@p.Telephone</td>
              <td><button class="btn-primary" @onclick="() => NewOrdonnanceFor(p.Id)">Nouvelle ordonnance</button></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>

@code {
  private bool loading = true;
  private string? error;
  private List<E_santeFrontend.Models.PatientDto> patients = new();

  protected override async Task OnInitializedAsync()
  {
    loading = true;
    try
    {
      patients = await PatientService.GetPatientsAsync();
    }
    catch (Exception ex) { error = ex.Message; }
    finally { loading = false; }
  }

  private void NewOrdonnanceFor(int patientId)
  {
    Nav.NavigateTo($"/ordonnances/nouvelle?patientId={patientId}");
  }
}
