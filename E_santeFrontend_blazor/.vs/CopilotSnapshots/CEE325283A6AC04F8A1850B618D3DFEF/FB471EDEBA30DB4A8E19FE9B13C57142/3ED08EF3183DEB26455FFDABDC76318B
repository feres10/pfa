@page "/dashboard/medecin"
@inject NavigationManager Nav
@inject E_santeFrontend.Services.PatientService PatientService
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService

<PageTitle>Dashboard Médecin</PageTitle>

<h3 class="mb-4">Tableau de bord Médecin</h3>
<div class="row g-3 mb-4">
  <div class="col-12 col-md-3"><Components.CardInfo Title="Patients" Subtitle="Suivis" Value="@patientsCount" Icon="bi-people" /></div>
  <div class="col-12 col-md-3"><Components.CardInfo Title="Rendez-vous" Subtitle="Aujourd'hui" Value="8" Icon="bi-calendar-check" /></div>
  <div class="col-12 col-md-3"><Components.CardInfo Title="Ordonnances" Subtitle="Créées" Value="@ordonnancesCount" Icon="bi-clipboard-check" /></div>
</div>
<div class="card shadow mb-4">
  <div class="card-body d-flex gap-2">
    <button class="btn btn-primary" @onclick="() => Nav.NavigateTo('/patients')">Gérer les patients</button>
    <button class="btn btn-secondary" @onclick="() => Nav.NavigateTo('/rendezvous')">Planning</button>
  </div>
</div>

@if (loading)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement...</span></div>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="row g-4">
        <div class="col-md-6">
            <CardInfo Title="Patients" Value="@patientsCount" />
        </div>
        <div class="col-md-6">
            <CardInfo Title="Ordonnances" Value="@ordonnancesCount" />
        </div>
    </div>
}

@code {
    private string patientsCount = "0";
    private string ordonnancesCount = "0";
    private bool loading;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var patients = await PatientService.GetPatientsAsync();
            var ords = await OrdonnanceService.GetOrdonnancesAsync();
            patientsCount = (patients?.Count ?? 0).ToString();
            ordonnancesCount = (ords?.Count ?? 0).ToString();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
