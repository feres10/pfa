@page "/dashboard/patient"
@inject E_santeFrontend.Services.OrdonnanceService OrdonnanceService
@inject E_santeFrontend.Services.NotificationService NotificationService
@inject NavigationManager Nav

<PageTitle>Dashboard Patient</PageTitle>

<h1 class="mb-4">Tableau de bord Patient</h1>

@if (loading)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement...</span></div>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="row g-4">
        <div class="col-md-6">
            <CardInfo Title="Mes ordonnances" Value="@ordonnancesCount" />
        </div>
        <div class="col-md-6">
            <CardInfo Title="Notifications" Value="@notificationsCount" />
        </div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-3">
            <CardInfo Title="Rendez-vous" Subtitle="À venir" Value="2" Icon="bi-calendar-event" />
        </div>
        <div class="col-12 col-md-3">
            <CardInfo Title="Ordonnances" Subtitle="Actives" Value="3" Icon="bi-file-medical" />
        </div>
        <div class="col-12 col-md-3">
            <CardInfo Title="Notifications" Subtitle="Non lues" Value="5" Icon="bi-bell" />
        </div>
    </div>
    <div class="card shadow mb-4">
        <div class="card-body d-flex gap-2">
            <button class="btn btn-primary" @onclick="() => Nav.NavigateTo('/rendezvous')">Voir les rendez-vous</button>
            <button class="btn btn-secondary" @onclick="() => Nav.NavigateTo('/ordonnances')">Mes ordonnances</button>
        </div>
    </div>
}

@code {
    private string ordonnancesCount = "0";
    private string notificationsCount = "0";
    private bool loading;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var ords = await OrdonnanceService.GetOrdonnancesAsync();
            var notifs = await NotificationService.GetNotificationsAsync();
            ordonnancesCount = (ords?.Count ?? 0).ToString();
            notificationsCount = (notifs?.Count ?? 0).ToString();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
