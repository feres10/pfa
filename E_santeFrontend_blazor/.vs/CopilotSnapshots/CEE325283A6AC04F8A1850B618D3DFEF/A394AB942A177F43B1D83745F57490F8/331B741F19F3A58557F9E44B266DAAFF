@page "/dashboard/pharmacien"
@inject E_santeFrontend.Services.StockService StockService
@inject E_santeFrontend.Services.MedicamentService MedicamentService
@inject NavigationManager Nav

<PageTitle>Dashboard Pharmacien</PageTitle>

<h1 class="mb-4">Tableau de bord Pharmacien</h1>

@if (loading)
{
    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Chargement...</span></div>
}
else if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger">@error</div>
}
else
{
    <div class="row g-4">
        <div class="col-md-6">
            <CardInfo Title="Mouvements de stock" Value="@movementsCount" />
        </div>
        <div class="col-md-6">
            <CardInfo Title="Médicaments" Value="@medicamentsCount" />
        </div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-3">
            <Components.CardInfo Title="Stock" Subtitle="Mouvements" Value="34" Icon="bi-box-seam" />
        </div>
        <div class="col-12 col-md-3">
            <Components.CardInfo Title="Médicaments" Subtitle="Références" Value="452" Icon="bi-capsule" />
        </div>
        <div class="col-12 col-md-3">
            <Components.CardInfo Title="Ordonnances" Subtitle="À préparer" Value="9" Icon="bi-receipt" />
        </div>
    </div>
    <div class="card shadow mb-4">
        <div class="card-body d-flex gap-2">
            <button class="btn btn-primary" @onclick="() => Nav.NavigateTo('/stock/movements')">Mouvements de stock</button>
            <button class="btn btn-secondary" @onclick="() => Nav.NavigateTo('/medicaments')">Catalogue médicaments</button>
        </div>
    </div>
}

@code {
    private string movementsCount = "0";
    private string medicamentsCount = "0";
    private bool loading;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        try
        {
            var movs = await StockService.GetMovementsAsync();
            var meds = await MedicamentService.GetMedicamentsAsync();
            movementsCount = (movs?.Count ?? 0).ToString();
            medicamentsCount = (meds?.Count ?? 0).ToString();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
