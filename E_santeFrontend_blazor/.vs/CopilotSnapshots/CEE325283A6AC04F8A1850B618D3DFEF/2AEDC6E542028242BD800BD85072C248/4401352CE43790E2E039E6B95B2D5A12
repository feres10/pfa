/* Modern theme variables */
:root {
  --bg: #0f172a; /* slate-900 */
  --bg-soft: #111827; /* gray-900 */
  --surface: #0b1220; /* deep surface */
  --surface-2: #111933;
  --text: #e5e7eb; /* gray-200 */
  --text-muted: #94a3b8; /* slate-400 */
  --primary: #6366f1; /* indigo-500 */
  --primary-600: #5458ee;
  --accent: #22d3ee; /* cyan-400 */
  --success: #10b981;
  --danger: #ef4444;
  --warning: #f59e0b;
  --border: #1f2937;
  --radius: 12px;
  --shadow: 0 10px 30px rgba(0,0,0,.35);
}

/* Base */
html, body { height: 100%; }
body {
  background: radial-gradient(1000px 500px at 10% 10%, rgba(34,211,238,.06), transparent 40%),
              radial-gradient(1000px 500px at 90% 10%, rgba(99,102,241,.06), transparent 40%),
              var(--bg);
  color: var(--text);
  font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji";
  letter-spacing: .1px;
}

h1, h2, h3, h4, h5 { color: var(--text); }
p { color: var(--text-muted); }

/* Layout */
.page { display: grid; grid-template-columns: 280px 1fr; min-height: 100vh; }
.sidebar {
  background: linear-gradient(180deg, rgba(17,24,39,.65), rgba(17,24,39,.3)), var(--bg-soft);
  border-right: 1px solid var(--border);
  backdrop-filter: blur(6px);
}
main { background: transparent; }
.top-row { display: flex; align-items: center; justify-content: space-between; }
.content { padding: 2rem; }

/* Nav */
.navbar-dark { background: transparent; }
.nav-scrollable { padding: 1rem; }
.nav-link { color: var(--text-muted); border-radius: 8px; }
.nav-link.active, .nav-link:hover { color: var(--text); background: rgba(99,102,241,.12); }

/* Cards */
.card { background: linear-gradient(180deg, rgba(17,24,39,.5), rgba(17,24,39,.2)); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); }
.card-title { color: var(--text); }
.card-text { color: var(--text-muted); }

/* Tables */
.table-responsive { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
.table { color: var(--text); margin-bottom: 0; }
.table-light { background: rgba(17,24,39,.4); color: var(--text-muted); }
.table-striped > tbody > tr:nth-of-type(odd) { --bs-table-accent-bg: rgba(99,102,241,.08); color: var(--text); }
.table-hover > tbody > tr:hover { background: rgba(34,211,238,.1); }
.table td, .table th { border-color: var(--border); }

/* Buttons */
.btn { border-radius: 10px; padding: .6rem 1rem; }
.btn-primary { background: var(--primary); border-color: var(--primary); }
.btn-primary:hover { background: var(--primary-600); border-color: var(--primary-600); }
.btn-danger { background: var(--danger); border-color: var(--danger); }
.btn-secondary { background: #334155; border-color: #334155; color: var(--text); }

/* Forms */
.form-control, input, select, textarea { background: var(--surface-2); border: 1px solid var(--border); color: var(--text); border-radius: 10px; }
.form-control:focus, input:focus, select:focus, textarea:focus { border-color: var(--accent); box-shadow: 0 0 0 .2rem rgba(34,211,238,.15); }
label { color: var(--text-muted); }

/* Modals */
.modal { background: rgba(2,6,23,.65); backdrop-filter: blur(6px); }
.modal-content { background: linear-gradient(180deg, rgba(17,24,39,.6), rgba(17,24,39,.3)); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); }
.modal-header, .modal-footer { border-color: var(--border); }

/* Badges */
.badge { border-radius: 9999px; }

/* Notification bell */
.bi-bell { color: var(--text-muted); font-size: 1.4rem; }

/* Utility */
.shadow { box-shadow: var(--shadow) !important; }
.rounded-xl { border-radius: var(--radius) !important; }
.text-muted { color: var(--text-muted) !important; }

/* Links */
a { color: var(--accent); text-decoration: none; }
a:hover { color: #67e8f9; }

html, body {
    font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    background-color: #f8f9fb;
    color: #212529;
}

h1:focus {
    outline: none;
}

a, .btn-link {
    color: #0d6efd;
}

.btn-primary {
    color: #fff;
    background: linear-gradient(90deg, #0d6efd 0%, #0b5ed7 100%);
    border-color: #0b5ed7;
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem rgba(13,110,253,.5);
}

.content {
    padding-top: 1.1rem;
}

.card-shadow {
    box-shadow: 0 10px 25px rgba(0,0,0,.05);
    border-radius: .75rem;
}

.valid.modified:not([type=checkbox]) {
    outline: 1px solid #26b050;
}

.invalid {
    outline: 1px solid red;
}

.validation-message {
    color: red;
}

#blazor-error-ui {
    color-scheme: light only;
    background: lightyellow;
    bottom: 0;
    box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.2);
    box-sizing: border-box;
    display: none;
    left: 0;
    padding: 0.6rem 1.25rem 0.7rem 1.25rem;
    position: fixed;
    width: 100%;
    z-index: 1000;
}

#blazor-error-ui .dismiss {
    cursor: pointer;
    position: absolute;
    right: 0.75rem;
    top: 0.5rem;
}

.blazor-error-boundary {
    background: url(data:image/svg+xml;base64, ) no-repeat 1rem/1.8rem, #b32121;
    padding: 1rem 1rem 1rem 3.7rem;
    color: white;
}

    .blazor-error-boundary::after {
        content: "An error has occurred."
    }

.loading-progress {
    position: relative;
    display: block;
    width: 8rem;
    height: 8rem;
    margin: 20vh auto 1rem auto;
}

    .loading-progress circle {
        fill: none;
        stroke: #e0e0e0;
        stroke-width: 0.6rem;
        transform-origin: 50% 50%;
        transform: rotate(-90deg);
    }

        .loading-progress circle:last-child {
            stroke: #0d6efd;
            stroke-dasharray: calc(3.141 * var(--blazor-load-percentage, 0%) * 0.8), 500%;
            transition: stroke-dasharray 0.05s ease-in-out;
        }

.loading-progress-text {
    position: absolute;
    text-align: center;
    font-weight: bold;
    inset: calc(20vh + 3.25rem) 0 auto 0.2rem;
}

    .loading-progress-text:after {
        content: var(--blazor-load-percentage-text, "Loading");
    }

code {
    color: #c02d76;
}

.form-floating > .form-control-plaintext::placeholder, .form-floating > .form-control::placeholder {
    color: var(--bs-secondary-color);
    text-align: end;
}

.form-floating > .form-control-plaintext:focus::placeholder, .form-floating > .form-control:focus::placeholder {
    text-align: start;
}