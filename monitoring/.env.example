# Prometheus Configuration
PROMETHEUS_RETENTION=15d
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# Grafana Configuration
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_INSTALL_PLUGINS=grafana-piechart-panel
GF_USERS_ALLOW_SIGN_UP=false
GF_SECURITY_DISABLE_BRUTE_FORCE_LOGIN_PROTECTION=false

# Network (shared with main docker-compose)
COMPOSE_PROJECT_NAME=esante

# Backend URL for Prometheus scraping
BACKEND_URL=backend:8080

# Frontend URL for Prometheus scraping
FRONTEND_URL=frontend:8080
